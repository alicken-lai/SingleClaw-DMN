# SingleClaw DMN – Environment Variables
# Copy this file to .env and fill in the values.
# .env is git-ignored; never commit real secrets.

# ─────────────────────────────────────────
# LLM provider selection
# ─────────────────────────────────────────
# SINGLECLAW_LLM_PROVIDER=openai   # openai | google | ollama  (default: openai)

# ─────────────────────────────────────────
# Auth Mode 1: API Key (fastest setup)
# ─────────────────────────────────────────
# Set whichever key matches your chosen provider:
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...

# Optional: override the default model
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash

# Optional: point at an OpenAI-compatible proxy (e.g. LM Studio, vLLM)
# OPENAI_BASE_URL=http://localhost:1234/v1

# Optional: Ollama base URL (used when SINGLECLAW_LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3

# ─────────────────────────────────────────
# Auth Mode 2: Browser Login (OAuth Device Flow)
# ─────────────────────────────────────────
# No API key required – run:  singleclaw auth login --provider google
#
# You must first register an OAuth 2.0 app in Google Cloud Console and set:
# GOOGLE_CLIENT_ID=<your-client-id>
#
# The access token is stored in .singleclaw/auth_token.json (git-ignored).

# ─────────────────────────────────────────
# Workspace paths (defaults shown; override if needed)
# ─────────────────────────────────────────
# SINGLECLAW_WORKSPACE_DIR=.singleclaw
# SINGLECLAW_SKILLS_DIR=skills

# ─────────────────────────────────────────
# Guardian Check behaviour
# ─────────────────────────────────────────
# SINGLECLAW_DRY_RUN=false
# SINGLECLAW_GUARDIAN_MODE=strict   # strict | permissive
