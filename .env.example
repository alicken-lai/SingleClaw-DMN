# SingleClaw DMN – Environment Variables
# Copy this file to .env and fill in the values.
# .env is git-ignored; never commit real secrets.

# ─────────────────────────────────────────
# LLM provider (optional – only required for AI-powered skill runs)
# ─────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────
# Workspace paths (defaults shown; override if needed)
# ─────────────────────────────────────────
# SINGLECLAW_WORKSPACE_DIR=.singleclaw
# SINGLECLAW_SKILLS_DIR=skills

# ─────────────────────────────────────────
# Guardian Check behaviour
# ─────────────────────────────────────────
# SINGLECLAW_DRY_RUN=false
# SINGLECLAW_GUARDIAN_MODE=strict   # strict | permissive
